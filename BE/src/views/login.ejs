<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Flashcard App</title>
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f4f7f6;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
      }
      .login-card {
        background: white;
        padding: 30px;
        border-radius: 8px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 350px;
      }
      h2 {
        text-align: center;
        color: #333;
        margin-bottom: 20px;
      }
      .form-group {
        margin-bottom: 15px;
      }
      .form-group label {
        display: block;
        margin-bottom: 5px;
        color: #666;
      }
      .form-group input {
        width: 100%;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-sizing: border-box; /* Đảm bảo padding không làm tràn width */
      }
      button {
        width: 100%;
        padding: 10px;
        background-color: #007bff;
        color: white;
        border: none;
        border-radius: 4px;
        font-size: 16px;
        cursor: pointer;
      }
      button:hover {
        background-color: #0056b3;
      }
      #error-msg {
        color: red;
        font-size: 14px;
        margin-bottom: 10px;
        text-align: center;
        display: none;
      }
    </style>
  </head>
  <body>
    <div class="login-card">
      <h2>Đăng Nhập</h2>
      <div id="error-msg"></div>
      <form id="loginForm">
        <div class="form-group">
          <label for="identifier">Email hoặc Username</label>
          <input
            type="text"
            id="identifier"
            name="identifier"
            placeholder="Nhập tài khoản..."
          />
        </div>
        <div class="form-group">
          <label for="password">Mật khẩu</label>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="Nhập mật khẩu..."
          />
        </div>
        <button type="submit" id="submitBtn">Đăng Nhập</button>
      </form>
      <hr style="margin: 20px 0" />

      <div
        id="g_id_onload"
        data-client_id="291689035282-8imcds82ko08fci0qfk23ij5569i2ki6.apps.googleusercontent.com"
        data-context="signin"
        data-ux_mode="popup"
        data-callback="handleCredentialResponse"
        data-auto_prompt="false"
      ></div>
      <div
        class="g_id_signin"
        data-type="standard"
        data-shape="rectangular"
        data-theme="outline"
        data-text="signin_with"
        data-size="large"
        data-logo_alignment="left"
      ></div>
    </div>

    <script>
      // Hàm này được gọi TỰ ĐỘNG khi user chọn tài khoản Google xong
      async function handleCredentialResponse(response) {
        // response.credential chính là idToken từ Google
        const idToken = response.credential;

        try {
          const res = await fetch("/api/auth/google", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ idToken }),
          });

          const data = await res.json();

          if (res.ok) {
            alert("Đăng nhập Google thành công!");
            window.location.href = data.redirect_url;
          } else {
            errorMsg.innerText = data.message;
            errorMsg.style.display = "block";
          }
        } catch (error) {
          console.error("Lỗi khi đăng nhập Google:", error);
        }
      }
      const loginForm = document.getElementById("loginForm");
      const errorMsg = document.getElementById("error-msg");
      const submitBtn = document.getElementById("submitBtn");

      loginForm.addEventListener("submit", async (e) => {
        e.preventDefault(); // Ngăn chặn form tự động reload trang

        // Lấy dữ liệu từ input
        const identifier = document.getElementById("identifier").value;
        const password = document.getElementById("password").value;

        // Xóa lỗi cũ và đổi trạng thái nút
        errorMsg.style.display = "none";
        submitBtn.innerText = "Đang xử lý...";
        submitBtn.disabled = true;

        try {
          // Gọi API Login
          const response = await fetch("/api/auth/login", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ identifier, password }),
          });

          const data = await response.json();

          if (response.ok) {
            // Đăng nhập thành công
            alert("Đăng nhập thành công!");
            // Điều hướng theo URL backend trả về
            window.location.href = data.redirect_url;
          } else {
            // Đăng nhập thất bại (sai pass, chưa xác thực, ...)
            errorMsg.innerText = data.message;
            errorMsg.style.display = "block";
          }
        } catch (error) {
          console.error("Lỗi:", error);
          errorMsg.innerText = "Không thể kết nối đến server!";
          errorMsg.style.display = "block";
        } finally {
          // Khôi phục lại nút bấm
          submitBtn.innerText = "Đăng Nhập";
          submitBtn.disabled = false;
        }
      });
    </script>
  </body>
</html>
